# GlacierNET-KZ API — Environment Configuration
# Copy this file to .env and fill in values

# --- Core ---
DATA_DIR=/app/data
REDIS_URL=redis://redis:6379/0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Upload limits ---
MAX_FILE_SIZE_MB=200
TASK_TIMEOUT=600

# --- LLM Gateway ---
# Options: openai, anthropic, groq, ollama, openrouter, google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_FALLBACK_MODEL=mistral:7b

# --- API Keys (set at least one) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# --- Ollama (local fallback) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Analysis language: en, ru, kk ---
ANALYSIS_LANG=ru

# --- Admin API (optional; protects /api/admin/* when set) ---
ADMIN_API_KEY=
