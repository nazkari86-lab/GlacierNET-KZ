# GlacierNET-KZ Web — Environment Configuration
# Copy this file to .env.local and fill in values

# --- API endpoint ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Public site URL (for sitemap, robots, Open Graph) ---
NEXT_PUBLIC_SITE_URL=https://github.com/nicklaua/GlacierNET-KZ

# --- Default language: en, ru, kk ---
NEXT_PUBLIC_DEFAULT_LOCALE=en

# --- Map tile server (optional) ---
NEXT_PUBLIC_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
