@page "/reports"
@using GlacierNET.Analysis.Models
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Reports - GlacierNET-KZ</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>📄 Reports</h2>
            <div>
                <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/reports/new")'>
                    <span class="me-1">➕</span> Generate Report
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <select class="form-select" @bind="filterType" @bind:after="LoadReports">
                <option value="">All Types</option>
                @foreach (var type in Enum.GetValues<ReportType>())
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <select class="form-select" @bind="filterYear" @bind:after="LoadReports">
                <option value="">All Years</option>
                @for (int year = DateTime.UtcNow.Year; year >= 2020; year--)
                {
                    <option value="@year">@year</option>
                }
            </select>
        </div>
        <div class="col-md-4 text-end">
            <span class="text-muted">@(reports?.Count ?? 0) reports</span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (reports != null && reports.Any())
    {
        <div class="row">
            @foreach (var report in reports)
            {
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@report.Title</h5>
                                <span class="badge @GetTypeBadge(report.Type)">@report.Type</span>
                            </div>
                            <p class="text-muted small mb-2">
                                📅 @report.CreatedAt.ToString("MMMM dd, yyyy") |
                                📊 @report.Format format
                            </p>

                            @if (report.StartDate.HasValue && report.EndDate.HasValue)
                            {
                                <p class="small mb-2">
                                    <strong>Period:</strong> @report.StartDate.Value.ToString("MMM dd") - @report.EndDate.Value.ToString("MMM dd, yyyy")
                                </p>
                            }

                            @if (!string.IsNullOrEmpty(report.Content))
                            {
                                <p class="small text-muted">
                                    @(report.Content.Length > 150 ? report.Content[..150] + "..." : report.Content)
                                </p>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between">
                                <small class="text-muted">
                                    ID: @report.Id.ToString()[..8]
                                </small>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary" @onclick="() => ViewHtml(report.Id)">🌐 View</button>
                                    <button class="btn btn-outline-secondary" @onclick="() => DownloadReport(report.Id, report.Format.ToString())">📥 Download</button>
                                    <button class="btn btn-outline-danger" @onclick="() => DeleteReport(report.Id)">🗑️</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="PreviousPage">Previous</button>
                    </li>
                    @for (int i = 1; i <= Math.Min(totalPages, 5); i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="NextPage">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info">
            <h5>No reports found</h5>
            <p>Generate a new report to get started.</p>
        </div>
    }
</div>

@code {
    private List<Report>? reports;
    private bool isLoading = true;
    private string filterType = string.Empty;
    private string filterYear = string.Empty;
    private int currentPage = 1;
    private int pageSize = 12;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadReports();
    }

    private async Task LoadReports()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("GlacierApi");
            var url = $"/api/report?page={currentPage}&pageSize={pageSize}";

            if (!string.IsNullOrEmpty(filterType) && Enum.TryParse<ReportType>(filterType, out var type))
                url = $"/api/report/type/{type}";
            else if (!string.IsNullOrEmpty(filterYear) && int.TryParse(filterYear, out var year))
                url = $"/api/report/annual/{year}";

            var response = await client.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<Report>>();
                reports = result?.Items.ToList();
                totalPages = (int)Math.Ceiling((result?.TotalCount ?? 0) / (double)pageSize);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading reports: {ex.Message}");
            reports = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ViewHtml(Guid reportId)
    {
        var client = HttpClientFactory.CreateClient("GlacierApi");
        var response = await client.GetAsync($"/api/report/{reportId}/html");
        if (response.IsSuccessStatusCode)
        {
            var html = await response.Content.ReadAsStringAsync();
            await JSRuntime.InvokeVoidAsync("open", "_blank");
        }
    }

    private async Task DownloadReport(Guid reportId, string format)
    {
        var client = HttpClientFactory.CreateClient("GlacierApi");
        var response = await client.GetAsync($"/api/report/{reportId}");
        if (response.IsSuccessStatusCode)
        {
            var report = await response.Content.ReadFromJsonAsync<Report>();
            if (report != null)
            {
                var fileName = $"report-{reportId.ToString()[..8]}.{format.ToLower()}";
                var content = System.Text.Encoding.UTF8.GetBytes(report.Content ?? string.Empty);
                await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(content));
            }
        }
    }

    private async Task DeleteReport(Guid reportId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this report?");
        if (confirmed)
        {
            try
            {
                var client = HttpClientFactory.CreateClient("GlacierApi");
                await client.DeleteAsync($"/api/report/{reportId}");
                await LoadReports();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting report: {ex.Message}");
            }
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadReports();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadReports();
        }
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadReports();
    }

    private string GetTypeBadge(ReportType type) => type switch
    {
        ReportType.AnnualSummary => "bg-primary",
        ReportType.TrendAnalysis => "bg-success",
        ReportType.AnomalyReport => "bg-danger",
        ReportType.ComparisonReport => "bg-info",
        _ => "bg-secondary"
    };

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
}
