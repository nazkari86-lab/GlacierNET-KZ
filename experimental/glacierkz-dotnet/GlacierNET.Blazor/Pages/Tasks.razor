@page "/tasks"
@using GlacierNET.Analysis.Models
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Processing Tasks - GlacierNET-KZ</PageTitle>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>⚙️ Processing Tasks</h2>
            <div>
                <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/tasks/new")'>
                    <span class="me-1">➕</span> New Task
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <select class="form-select" @bind="filterStatus" @bind:after="LoadTasks">
                <option value="">All Statuses</option>
                @foreach (var status in Enum.GetValues<Models.TaskStatus>())
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <button class="btn btn-outline-secondary" @onclick="RefreshTasks">🔄 Refresh</button>
        </div>
        <div class="col-md-4 text-end">
            <span class="text-muted">@(tasks?.Count ?? 0) tasks</span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (tasks != null && tasks.Any())
    {
        <div class="row">
            @foreach (var task in tasks)
            {
                <div class="col-md-6 mb-3">
                    <div class="card @(task.Status == Models.TaskStatus.Failed ? "border-danger" : task.Status == Models.TaskStatus.Completed ? "border-success" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@task.Name</h5>
                                <span class="badge @GetTaskStatusBadge(task.Status)">@task.Status</span>
                            </div>
                            <p class="text-muted small mb-2">@task.TaskType</p>

                            @if (task.Status == Models.TaskStatus.Processing)
                            {
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small>Progress</small>
                                        <small>@task.ProgressPercent.ToString("F1")%</small>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-primary" style="width: @task.ProgressPercent%"></div>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between text-muted small">
                                    <span>@task.CompletedItems / @task.TotalItems items</span>
                                    @if (task.EstimatedTimeRemaining.HasValue)
                                    {
                                        <span>ETA: @FormatTimeSpan(task.EstimatedTimeRemaining.Value)</span>
                                    }
                                </div>
                            }
                            else if (task.Status == Models.TaskStatus.Completed)
                            {
                                <div class="text-success small">
                                    ✅ Completed @task.CompletedItems items in @FormatSeconds(task.ActualDurationSeconds)
                                </div>
                            }
                            else if (task.Status == Models.TaskStatus.Failed)
                            {
                                <div class="text-danger small">
                                    ❌ @task.ErrorMessage
                                </div>
                            }

                            <div class="mt-3 d-flex gap-2">
                                @if (task.Status == Models.TaskStatus.Queued || task.Status == Models.TaskStatus.Paused)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => StartTask(task.Id)">▶️ Start</button>
                                }
                                @if (task.Status == Models.TaskStatus.Processing)
                                {
                                    <button class="btn btn-sm btn-warning" @onclick="() => PauseTask(task.Id)">⏸️ Pause</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => CancelTask(task.Id)">⏹️ Cancel</button>
                                }
                                @if (task.Status == Models.TaskStatus.Completed || task.Status == Models.TaskStatus.Failed)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task.Id)">🗑️ Delete</button>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <small class="text-muted">
                                Created: @task.CreatedAt.ToString("MMM dd, HH:mm") |
                                @(task.CompletedAt?.ToString("Completed: MMM dd, HH:mm") ?? $"Duration: {FormatSeconds(task.ActualDurationSeconds)}")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="PreviousPage">Previous</button>
                    </li>
                    @for (int i = 1; i <= Math.Min(totalPages, 5); i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="NextPage">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info">
            <h5>No tasks found</h5>
            <p>Create a new processing task to get started.</p>
        </div>
    }
</div>

@code {
    private List<ProcessingTask>? tasks;
    private bool isLoading = true;
    private string filterStatus = string.Empty;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("GlacierApi");
            var url = $"/api/task?page={currentPage}&pageSize={pageSize}";

            if (!string.IsNullOrEmpty(filterStatus))
                url = $"/api/task/status/{filterStatus}";

            var response = await client.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<ProcessingTask>>();
                tasks = result?.Items.ToList();
                totalPages = (int)Math.Ceiling((result?.TotalCount ?? 0) / (double)pageSize);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tasks: {ex.Message}");
            tasks = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshTasks()
    {
        await LoadTasks();
    }

    private async Task StartTask(Guid taskId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GlacierApi");
            await client.PostAsync($"/api/task/{taskId}/start", null);
            await LoadTasks();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting task: {ex.Message}");
        }
    }

    private async Task PauseTask(Guid taskId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GlacierApi");
            await client.PostAsync($"/api/task/{taskId}/pause", null);
            await LoadTasks();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error pausing task: {ex.Message}");
        }
    }

    private async Task CancelTask(Guid taskId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to cancel this task?");
        if (confirmed)
        {
            try
            {
                var client = HttpClientFactory.CreateClient("GlacierApi");
                await client.PostAsync($"/api/task/{taskId}/cancel", null);
                await LoadTasks();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error cancelling task: {ex.Message}");
            }
        }
    }

    private async Task DeleteTask(Guid taskId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this task?");
        if (confirmed)
        {
            try
            {
                var client = HttpClientFactory.CreateClient("GlacierApi");
                await client.DeleteAsync($"/api/task/{taskId}");
                await LoadTasks();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting task: {ex.Message}");
            }
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadTasks();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadTasks();
        }
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadTasks();
    }

    private string GetTaskStatusBadge(Models.TaskStatus status) => status switch
    {
        Models.TaskStatus.Completed => "bg-success",
        Models.TaskStatus.Processing => "bg-primary",
        Models.TaskStatus.Queued => "bg-secondary",
        Models.TaskStatus.Paused => "bg-warning",
        Models.TaskStatus.Failed => "bg-danger",
        Models.TaskStatus.Cancelled => "bg-dark",
        _ => "bg-secondary"
    };

    private string FormatTimeSpan(TimeSpan ts) => ts.TotalHours >= 1
        ? $"{(int)ts.TotalHours}h {ts.Minutes}m"
        : $"{ts.Minutes}m {ts.Seconds}s";

    private string FormatSeconds(double? seconds)
    {
        if (!seconds.HasValue) return "N/A";
        var ts = TimeSpan.FromSeconds(seconds.Value);
        return FormatTimeSpan(ts);
    }

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
}
