{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=glacierkz;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "GrpcServices": {
    "PythonMlService": "http://localhost:50051"
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "GlacierNET.KZ",
    "Audience": "GlacierNET.KZ.Api",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7002", "http://localhost:5002" ]
  },
  "ReportSettings": {
    "TemplatePath": "Templates/Reports",
    "OutputPath": "Output/Reports"
  },
  "SatelliteImageSettings": {
    "StoragePath": "Data/SatelliteImages",
    "MaxFileSizeMb": 500,
    "SupportedFormats": [ ".tif", ".tiff", ".jp2", ".png" ]
  }
}
